# ── Required ──────────────────────────────────────────────
# Google Gemini API key (note the double "Y" — matches process.env.GEMINI_API_KEYY)
# Powers persona chat, function calling AND the consensus evaluator.
GEMINI_API_KEYY=your_google_gemini_api_key

# ── Tools (optional, recommended) ─────────────────────────
# Tavily powers the searchWeb tool for live web results.
# Without it, searchWeb degrades gracefully ("Unable to retrieve live information.")
# Get a key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key

# ── Self-Consistency Answer Engine ────────────────────────
# OpenRouter powers the default consensus models (free tiers available).
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional — set these to switch consensus models to direct paid providers
# (then point entries in lib/ai/models.ts at them; no other code changes):
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# GEMINI_API_KEY=your_google_gemini_api_key   (standard name; GEMINI_API_KEYY also works)
