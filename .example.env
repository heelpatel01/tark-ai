# ── Required ──────────────────────────────────────────────
# Google Gemini API key (note the double "Y" — matches process.env.GEMINI_API_KEYY)
GEMINI_API_KEYY=your_google_gemini_api_key

# ── Tools (optional, recommended) ─────────────────────────
# Tavily powers the searchWeb tool for live web results.
# Without it, searchWeb degrades gracefully ("Unable to retrieve live information.")
# Get a key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key

# ── Legacy / unused ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
